{
  "expo": {
    "name": "StyleSense AI",
    "slug": "stylesense-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usamos sua localização para sugerir looks adequados ao clima de hoje."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita o acesso às fotos para cadastrar suas roupas.",
          "cameraPermission": "Permita o acesso à câmera para fotografar suas roupas."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Usamos sua localização para sugerir looks adequados ao clima de hoje."
      }
    },
    "android": {
      "package": "com.aline.stylesense",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F2E7F1",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "StyleSense AI",
      "shortName": "StyleSense",
      "themeColor": "#A86E9B",
      "backgroundColor": "#F8F1ED",
      "display": "standalone",
      "lang": "pt-BR"
    }
  }
}
